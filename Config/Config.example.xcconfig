// Duplicate this file as Config/Config.xcconfig (gitignored) and fill in
// real values — in Xcode: right-click this file → Duplicate, then rename.
// This file is optional: without it the app runs local-only with every
// backend disabled (defaults come from Base.xcconfig).
//
// NOTE: "//" starts a comment in xcconfig, so URLs must be written with the
// $() escape as below.

// Supabase (Project Settings → API)
SUPABASE_URL = https:/$()/YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY =

// Sentry (Project Settings → Client Keys DSN)
SENTRY_DSN =

// PostHog (Project Settings → API key)
POSTHOG_API_KEY =
POSTHOG_HOST = https:/$()/eu.i.posthog.com
